{
  "providers": {
    "scads": {
      "apiKey": "${SCADSAI_LLM_API_KEY}",
      "apiBase": "https://llm.scads.ai/v1"
    }
  },
  "modelPresets": {
    "primary": {
      "label": "llm.scads.ai primary",
      "provider": "scads",
      "model": "REPLACE_WITH_GEMMA4_MODEL_ID",
      "maxTokens": 4096,
      "contextWindowTokens": 65536,
      "temperature": 0.1
    },
    "glm52": {
      "label": "llm.scads.ai GLM 5.2",
      "provider": "scads",
      "model": "REPLACE_WITH_GLM52_MODEL_ID",
      "maxTokens": 4096,
      "contextWindowTokens": 65536,
      "temperature": 0.1
    },
    "kimi27Code": {
      "label": "llm.scads.ai Kimi 2.7 Code",
      "provider": "scads",
      "model": "REPLACE_WITH_KIMI27_CODE_MODEL_ID",
      "maxTokens": 4096,
      "contextWindowTokens": 65536,
      "temperature": 0.1
    }
  },
  "agents": {
    "defaults": {
      "modelPreset": "primary"
    }
  },
  "channels": {
    "websocket": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 8765,
      "tokenIssueSecret": "${NANOBOT_WEBUI_SECRET}",
      "websocketRequiresToken": true,
      "allowFrom": ["*"],
      "streaming": true
    }
  },
  "tools": {
    "restrictToWorkspace": true
  }
}
