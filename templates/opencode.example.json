          }
        },
        "moonshotai/Kimi-K2.7-Code": {
          "name": "moonshotai/Kimi-K2.7-Code",
          "limit": {
            "context": 262000,
            "output": 128000
          }
        },
        "google/gemma-4-31B-it": {
          "name": "google/gemma-4-31B-it",
          "limit": {
            "context": 262000,
            "output": 128000
          }
        }
      }
